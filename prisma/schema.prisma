// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────

enum BloodGroup {
  A_POS // A+
  A_NEG // A-
  B_POS // B+
  B_NEG // B-
  AB_POS // AB+
  AB_NEG // AB-
  O_POS // O+
  O_NEG // O-
}

enum Department {
  TE // Textile Engineering
  IP // Industrial & Production Engineering
  EE // Electrical Engineering
  CS // Computer Science & Engineering
  FD // Fashion Design
}

enum AvailabilityStatus {
  AVAILABLE
  UNAVAILABLE
  INACTIVE
}

enum DeletionStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum NotificationType {
  ELIGIBILITY_RESTORED
  BLOOD_REQUEST
  BROADCAST
  CONTACT_REVEALED
  PROFILE_VERIFIED
  DELETION_UPDATE
}

// ─── USERS ───────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String?
  googleId          String?   @unique
  emailVerified     Boolean   @default(false)
  verifyToken       String?
  verifyTokenExpiry DateTime?
  resetToken        String?
  resetTokenExpiry  DateTime?
  role              UserRole  @default(USER)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastLoginAt       DateTime?
  isActive          Boolean   @default(true)

  // Relations
  profile         DonorProfile?
  notifications   Notification[]
  contactReveals  ContactReveal[]  @relation("Requester")
  deletionRequest DeletionRequest?
  bloodRequests   BloodRequest[]

  assignedAdminBy   User?           @relation("AdminAssignment", fields: [assignedAdminById], references: [id])
  assignedAdminById String?
  adminAssignees    User[]          @relation("AdminAssignment")
  adminAuditLogs    AdminAuditLog[]

  @@index([email])
  @@index([role])
  @@index([isActive])
}

// ─── DONOR PROFILES ──────────────────────────────────────────

model DonorProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identity
  fullName   String
  department Department
  idNumber   String
  studentId  String     @unique
  batch      Int
  phone      String
  email      String

  // Location
  currentLocation String
  hometown        String

  // Blood & Donation
  bloodGroup         BloodGroup
  lastDonationDate   DateTime?
  totalDonations     Int                @default(0)
  availabilityStatus AvailabilityStatus @default(AVAILABLE)
  availabilityNote   String?
  willingToDonate    Boolean            @default(true)

  // Verification
  seedMatched     Boolean   @default(false)
  seedMatchedAt   DateTime?
  profileComplete Boolean   @default(false)
  profilePhoto    String? // Supabase Storage URL

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  donationHistory DonationLog[]
  contactReveals  ContactReveal[]  @relation("DonorRevealed")
  deletionRequest DeletionRequest?

  @@index([bloodGroup])
  @@index([department])
  @@index([batch])
  @@index([willingToDonate, availabilityStatus])
  @@index([studentId])
}

// ─── SEED DATA (READ-ONLY IMPORT) ────────────────────────────

model SeedDonor {
  id         String     @id @default(cuid())
  studentId  String     @unique
  fullName   String
  bloodGroup BloodGroup
  batch      String?
  department String?
  hometown   String?
  phone      String?
  isClaimed  Boolean    @default(false)
  claimedAt  DateTime?
  importedAt DateTime   @default(now())

  @@index([studentId])
  @@index([bloodGroup])
  @@index([isClaimed])
}

// ─── DONATION LOG ─────────────────────────────────────────────

model DonationLog {
  id           String       @id @default(cuid())
  profileId    String
  profile      DonorProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  donationDate DateTime
  location     String
  notes        String?
  verified     Boolean      @default(false)
  verifiedBy   String?
  createdAt    DateTime     @default(now())

  @@index([profileId])
  @@index([donationDate])
}

// ─── DELETION REQUESTS ────────────────────────────────────────

model DeletionRequest {
  id          String         @id @default(cuid())
  userId      String         @unique
  user        User           @relation(fields: [userId], references: [id])
  profileId   String         @unique
  profile     DonorProfile   @relation(fields: [profileId], references: [id])
  seedMatched Boolean
  status      DeletionStatus @default(PENDING)
  adminNote   String?
  requestedAt DateTime       @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?

  @@index([status])
  @@index([requestedAt])
}

// ─── CONTACT REVEALS ─────────────────────────────────────────

model ContactReveal {
  id          String       @id @default(cuid())
  requesterId String
  requester   User         @relation("Requester", fields: [requesterId], references: [id])
  donorId     String
  donor       DonorProfile @relation("DonorRevealed", fields: [donorId], references: [id])
  revealedAt  DateTime     @default(now())
  purpose     String?

  @@unique([requesterId, donorId])
  @@index([donorId])
  @@index([revealedAt])
}

// ─── NOTIFICATIONS ────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

// ─── BLOOD REQUESTS ───────────────────────────────────────────

model BloodRequest {
  id           String     @id @default(cuid())
  requesterId  String
  requester    User       @relation(fields: [requesterId], references: [id])
  bloodGroup   BloodGroup
  urgency      String // "routine" | "urgent" | "critical"
  location     String
  hospital     String?
  neededBy     DateTime?
  message      String?
  contactPhone String
  status       String     @default("open") // open | matched | fulfilled | cancelled
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([bloodGroup])
  @@index([urgency])
  @@index([status])
  @@index([createdAt])
}

// ─── ADMIN AUDIT LOG ─────────────────────────────────────────

model AdminAuditLog {
  id             String   @id @default(cuid())
  adminId        String
  admin          User     @relation(fields: [adminId], references: [id])
  action         String
  targetUserId   String?
  targetUserName String?
  details        String?
  createdAt      DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
}
